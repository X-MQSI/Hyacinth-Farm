{
  "name": "hyacinth-farm-server",
  "version": "2.0.0",
  "description": "Hyacinth Farm real-time monitoring server — ESP32-CAM + sensors dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "pm2:start": "pm2 start server.js --name hyacinth-farm",
    "pm2:stop": "pm2 stop hyacinth-farm",
    "pm2:restart": "pm2 restart hyacinth-farm",
    "pm2:delete": "pm2 delete hyacinth-farm",
    "pm2:logs": "pm2 logs hyacinth-farm",
    "pm2:status": "pm2 status hyacinth-farm"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sql.js": "^1.10.3"
  },
